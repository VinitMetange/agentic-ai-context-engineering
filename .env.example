# Agentic AI Context Engineering - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Vector Store (ChromaDB - local, no config needed)
# For pgvector:
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/vector_db

# Application Settings
MAX_CONTEXT_TOKENS=8000
LOG_LEVEL=INFO
EMBEDDING_MODEL=text-embedding-3-small
